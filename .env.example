# Copy to .env and edit.  Loaded by whatever launches padel_backend.py
# (e.g. `set -a; source .env; set +a; python padel_backend.py`).

# Bearer token shared with every ESP32-C3 node (config.h SUMMA_NODE_TOKEN).
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SUMMA_NODE_TOKEN=change-me-in-env

# Network binding.
SUMMA_HOST=0.0.0.0
SUMMA_PORT=5000

# Logging level: DEBUG / INFO / WARNING / ERROR.
SUMMA_LOG_LEVEL=INFO
